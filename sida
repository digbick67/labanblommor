<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <title>Blomidentifiering – Laban Broman TE3A</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 700px;
      margin: 40px auto;
      padding: 20px;
      background: #f5f5f5;
    }
    header {
      background: #ffffff;
      padding: 15px 20px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      margin-bottom: 25px;
    }
    .card {
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      margin-bottom: 20px;
    }
    img {
      max-width: 100%;
      margin-top: 15px;
      border-radius: 8px;
    }
    #result {
      font-size: 1.2rem;
      margin-top: 15px;
      font-weight: bold;
    }
  </style>
</head>
<body>

  <header>
    <h1>🌸 Blomidentifiering</h1>
    <p>Av: <strong>Laban Broman</strong> – Klass <strong>TE3A</strong></p>
  </header>

  <p>Ladda upp en bild så analyserar modellen vilken blomart det är.</p>

  <div class="card">
    <input type="file" id="imageInput" accept="image/*">
    <img id="preview" style="display:none;">
    <div id="result"></div>
  </div>

  <script>
    const input = document.getElementById("imageInput");
    const preview = document.getElementById("preview");
    const result = document.getElementById("result");

    input.addEventListener("change", async () => {
      const file = input.files[0];
      if (!file) return;

      // Visa förhandsgranskning
      preview.src = URL.createObjectURL(file);
      preview.style.display = "block";
      result.textContent = "Analyserar...";

      // Skicka bilden till ditt API / modell
      const formData = new FormData();
      formData.append("image", file);

      try {
        const response = await fetch("https://din-api-url-här.com/predict", {
          method: "POST",
          body: formData
        });

        const data = await response.json();

        // Förväntat svar:
        // { species: "Ros", probability: 0.92 }

        result.textContent =
          `Art: ${data.species} — Sannolikhet: ${(data.probability * 100).toFixed(1)}%`;

      } catch (err) {
        result.textContent = "Fel vid analysen.";
        console.error(err);
      }
    });
  </script>

</body>
</html>
